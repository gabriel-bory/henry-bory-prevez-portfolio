---
import StatusBadge from '../ui/StatusBadge.astro';
import { withBase } from '../../utils/url';

type Locale = 'es' | 'en' | 'nl';

interface Item {
  title: string;
  description: string;
  pdf?: string;
  docx?: string;
  status: string;
}

interface Props {
  item: Item;
  locale?: Locale;
}

const { item, locale = 'es' } = Astro.props;

const labels = {
  es: { pdfPending: 'PDF pendiente', docxPending: 'DOCX pendiente' },
  en: { pdfPending: 'PDF pending', docxPending: 'DOCX pending' },
  nl: { pdfPending: 'PDF in voorbereiding', docxPending: 'DOCX in voorbereiding' },
} as const;
---

<article class="card download-card">
  <div class="download-card__head">
    <h3>{item.title}</h3>
    <StatusBadge status={item.status} />
  </div>

  <p>{item.description}</p>

  <div class="button-row">
    {item.pdf ? (
      <a class="button" href={withBase(item.pdf)} download>PDF</a>
    ) : (
      <span class="button disabled" aria-disabled="true">{labels[locale].pdfPending}</span>
    )}

    {item.docx ? (
      <a class="button secondary" href={withBase(item.docx)} download>DOCX</a>
    ) : (
      <span class="button secondary disabled" aria-disabled="true">{labels[locale].docxPending}</span>
    )}
  </div>
</article>
