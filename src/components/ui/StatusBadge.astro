---
interface Props {
  status?: string;
}

const { status = 'Pendiente' } = Astro.props;
const normalized = status.toLowerCase();
const readyKeywords = ['disponible', 'available', 'beschikbaar', 'disponível', 'verfügbar', 'disponibile'];
const statusClass = readyKeywords.some((keyword) => normalized.includes(keyword)) ? 'is-ready' : 'is-pending';
---

<span class={`status-badge ${statusClass}`}>{status}</span>
