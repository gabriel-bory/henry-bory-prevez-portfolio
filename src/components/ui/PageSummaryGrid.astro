---
import { withBase } from '../../utils/url';

interface SummaryItem {
  title: string;
  description: string;
  href?: string;
  cta?: string;
}

interface Props {
  items: SummaryItem[];
}

const { items } = Astro.props;
---

<div class="summary-grid">
  {items.map((item) => (
    <article class="card summary-card">
      <h3>{item.title}</h3>
      <p>{item.description}</p>
      {item.href && (
        <a class="text-link" href={withBase(item.href)}>
          {item.cta ?? 'Ver más'}
        </a>
      )}
    </article>
  ))}
</div>
