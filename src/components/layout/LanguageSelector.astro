---
import { languages } from '../../data/languages';
import { getCurrentLocale, getLocalizedPath } from '../../i18n/routes';
import { languageSelectorLabels } from '../../i18n/ui';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;
const currentLocale = getCurrentLocale(currentPath);
const label = languageSelectorLabels[currentLocale];
---

<div class="language-select" aria-label={label}>
  <label class="language-select__label" for="language-select">{label}</label>
  <select
    id="language-select"
    class="language-select__control"
    data-language-select
    aria-label={label}
    title={`${label}: ${languages.find((language) => language.code === currentLocale)?.fullLabel ?? currentLocale}`}
  >
    {languages.map((language) => (
      <option
        value={getLocalizedPath(currentPath, language.code)}
        selected={language.code === currentLocale}
      >
        {language.label}
      </option>
    ))}
  </select>
</div>
