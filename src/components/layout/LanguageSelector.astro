---
import { languages } from '../../data/languages';
import { withBase } from '../../utils/url';

const activeLanguage = languages.find((language) => language.status === 'active') ?? languages[0];
---

<div class="language-select" aria-label="Selector de idioma">
  <label class="language-select__label" for="language-select">Seleccionar idioma</label>
  <select
    id="language-select"
    class="language-select__control"
    data-language-select
    aria-label="Seleccionar idioma"
    title={`Idioma actual: ${activeLanguage.fullLabel}`}
  >
    {languages.map((language) => (
      <option
        value={withBase(language.href)}
        selected={language.code === activeLanguage.code}
        disabled={language.status !== 'active'}
      >
        {language.status === 'active' ? language.label : `${language.label} · prep.`}
      </option>
    ))}
  </select>
</div>

