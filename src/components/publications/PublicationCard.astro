---
interface Props {
  title: string;
  authors: string[];
  year: number;
  venue?: string;
  area: string;
  doi?: string;
  url?: string;
  evidenceStatus: string;
}

const { title, authors, year, venue, area, doi, url, evidenceStatus } = Astro.props;
---

<article class="card publication-card">
  <p class="eyebrow">{area} · {year}</p>
  <h2>{title}</h2>
  <p><strong>Autores:</strong> {authors.join(', ')}</p>
  {venue && <p><strong>Fuente:</strong> {venue}</p>}
  {doi && <p><strong>DOI:</strong> {doi}</p>}
  <p class="small"><strong>Estado de evidencia:</strong> {evidenceStatus}</p>
  {url && <a class="text-link" href={url} target="_blank" rel="noopener noreferrer">Ver fuente</a>}
</article>
