---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../ui/PageIntro.astro';
import { localizedPages, type LocalizedPageKey } from '../../data/localized-pages';
import { localizedRoutes } from '../../i18n/routes';
import type { Locale } from '../../i18n/locales';

interface Props {
  locale: Locale;
  pageKey: LocalizedPageKey;
}

const { locale, pageKey } = Astro.props;
const page = localizedPages[locale][pageKey];
const contactHref = localizedRoutes.contact[locale];
const cvHref = localizedRoutes.cv[locale];
---

<BaseLayout title={`${page.title} | Henry Bory Prevez`}>
  <PageIntro
    eyebrow={page.eyebrow}
    title={page.title}
    lead={page.lead}
    summaryTitle={page.summaryTitle}
    summary={page.summary}
    actions={[
      { label: locale === 'es' ? 'Ver CV' : locale === 'en' ? 'View CV' : 'CV', href: cvHref },
      { label: locale === 'es' ? 'Contacto' : locale === 'en' ? 'Contact' : 'Contact', href: contactHref, variant: 'secondary' },
    ]}
  />
</BaseLayout>
