---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../ui/PageIntro.astro';
import { getLocalizedRouteByKey, type RouteKey } from '../../i18n/routes';
import { preparationCopy } from '../../i18n/ui';
import type { Locale } from '../../i18n/locales';

interface Props {
  locale: Locale;
  routeKey: RouteKey;
  title: string;
  eyebrow: string;
  lead: string;
  summaryTitle: string;
  summary: string;
}

const { locale, routeKey, title, eyebrow, lead, summaryTitle, summary } = Astro.props;
const copy = preparationCopy[locale];
const spanishHref = getLocalizedRouteByKey(routeKey, 'es');
const homeHref = getLocalizedRouteByKey('home', locale);
---

<BaseLayout title={`${title} | Henry Bory Prevez`}>
  <PageIntro
    eyebrow={eyebrow}
    title={title}
    lead={lead}
    summaryTitle={summaryTitle}
    summary={summary}
    actions={[
      { label: copy.spanishButton, href: spanishHref.replace(import.meta.env.BASE_URL, '') },
      { label: copy.homeButton, href: homeHref.replace(import.meta.env.BASE_URL, ''), variant: 'secondary' },
    ]}
  />

  <section class="section section-tight">
    <div class="container">
      <article class="card i18n-status-card">
        <p class="eyebrow">{copy.badge}</p>
        <h2>{copy.statusTitle}</h2>
        <p>{copy.statusText}</p>
      </article>
    </div>
  </section>
</BaseLayout>
