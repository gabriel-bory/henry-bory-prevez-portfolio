---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/ui/PageIntro.astro';
import { getCollection } from 'astro:content';
import { sectionSummaries } from '../data/section-summaries';

const softwareItems = await getCollection('software');
const sortedSoftware = softwareItems.map((item) => item.data).sort((a,b)=> (b.year ?? 0) - (a.year ?? 0) || a.title.localeCompare(b.title));
---

<BaseLayout title="Software y registros | Henry Bory Prevez">
  <PageIntro {...sectionSummaries.software} actions={[{ label: 'Ver proyectos', href: 'proyectos/' }, { label: 'Ver investigación', href: 'investigacion/', variant: 'secondary' }]} />

  <section class="section section-tight">
    <div class="container">
      <div class="callout">
        <strong>Criterio editorial:</strong> se distingue entre software registrado, herramienta docente, recurso computacional y prototipo. Ningún resultado se presenta como patente sin documento oficial de respaldo.
      </div>

      <div class="card-grid software-grid">
        {sortedSoftware.map((item) => (
          <article class="card software-card">
            <p class="eyebrow">{item.type}</p>
            <div class="software-card__head">
              <h2>{item.title}</h2>
              {(item.year ?? 0) > 0 ? <span class="status-badge is-ready">{item.year}</span> : null}
            </div>
            {item.registration && <p><strong>Referencia:</strong> {item.registration}</p>}
            <p>{item.summary}</p>
            <p class="small"><strong>Estado de evidencia:</strong> {item.evidenceStatus}</p>
          </article>
        ))}
      </div>

      <section class="section-mini">
        <h2>Cómo se seguirá completando esta sección</h2>
        <div class="card-grid">
          <article class="card"><h3>Ficha técnica</h3><p>Se completarán objetivo, plataforma, lenguaje, autores, institución, año y uso recomendado.</p></article>
          <article class="card"><h3>Evidencia documental</h3><p>Los registros mencionados en el currículo se ampliarán solo con certificados, fichas o documentos oficiales.</p></article>
          <article class="card"><h3>Relación con investigación</h3><p>Cada software se enlazará con líneas de trabajo, publicaciones o proyectos para reforzar la trazabilidad del portafolio.</p></article>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
