---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PublicationCard from '../../components/publications/PublicationCard.astro';
import { getCollection } from 'astro:content';

const publications = await getCollection('publications');
const sorted = publications
  .map((entry) => ({ slug: entry.id.replace(/\.md$/, ''), ...entry.data }))
  .sort((a, b) => b.year - a.year);
---

<BaseLayout title="Publicaciones científicas | Henry Bory Prevez">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Producción científica</p>
      <h1>Publicaciones seleccionadas</h1>
      <p class="lead">Catálogo inicial de publicaciones y resultados científicos organizados por área temática. Cada tarjeta incluye resumen, estado de evidencia y botón para ampliar detalles.</p>

      <div class="card-grid publication-grid">
        {sorted.map((publication) => <PublicationCard {...publication} />)}
      </div>
    </div>
  </section>
</BaseLayout>
