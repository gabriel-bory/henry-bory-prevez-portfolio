---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/ui/PageIntro.astro';
import DownloadCard from '../components/cv/DownloadCard.astro';
import { cvDownloads } from '../data/cv-downloads';
import { sectionSummaries } from '../data/section-summaries';
import { site } from '../data/site';
import { withBase } from '../utils/url';

const qrImage = withBase('images/qr/henry-bory-prevez-cv-qr.png');
---

<BaseLayout title="CV descargable | Henry Bory Prevez">
  <PageIntro {...sectionSummaries.cv} actions={[{ label: 'Ver publicaciones', href: 'publicaciones/' }, { label: 'Ver software', href: 'software/', variant: 'secondary' }]} />

  <section class="section section-tight">
    <div class="container">
      <div class="language-sections">
        {cvDownloads.map((group) => (
          <section class="language-section" aria-labelledby={`cv-${group.locale}`}>
            <h2 id={`cv-${group.locale}`}>{group.language}</h2>
            <p class="small">{group.availabilityNote}</p>
            <div class="card-grid">{group.items.map((item) => <DownloadCard item={item} locale={group.locale} />)}</div>
          </section>
        ))}
      </div>

      <section class="qr-section">
        <div class="card qr-card">
          <div>
            <p class="eyebrow">QR profesional</p>
            <h2>Acceso directo al CV actualizado</h2>
            <p>Este código dirige a la página pública de CV y debe validarse después del despliegue en GitHub Pages antes de integrarlo en documentos finales.</p>
            <p class="small"><strong>URL:</strong> {site.cvUrl}</p>
          </div>
          <img src={qrImage} alt="Código QR hacia la página de CV del portafolio profesional" class="qr-image" width="220" height="220" />
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
