---
import BaseLayout from '../layouts/BaseLayout.astro';
import DownloadCard from '../components/cv/DownloadCard.astro';
import { cvDownloads } from '../data/cv-downloads';
import { site } from '../data/site';
import { withBase } from '../utils/url';

const qrImage = withBase('images/qr/henry-bory-prevez-cv-qr.png');
---

<BaseLayout title="CV descargable | Henry Bory Prevez">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Currículum Vitae · Descargas profesionales</p>

      <h1>CV descargable</h1>

      <p class="lead">
        Seleccione el idioma y el tipo de currículum que desea consultar o descargar.
        Las versiones públicas se organizan por uso: ejecutivo, académico, ATS, resumen breve y dossier.
      </p>

      <div class="language-sections">
        {cvDownloads.map((group) => (
          <section class="language-section" aria-labelledby={`cv-${group.language}`}>
            <h2 id={`cv-${group.language}`}>{group.language}</h2>
            <div class="card-grid">
              {group.items.map((item) => (
                <DownloadCard item={item} />
              ))}
            </div>
          </section>
        ))}
      </div>

      <section class="qr-section">
        <div class="card qr-card">
          <div>
            <p class="eyebrow">QR profesional</p>
            <h2>Acceso directo al CV actualizado</h2>
            <p>
              Este código apunta a la página pública de CV. Debe validarse después del primer despliegue
              en GitHub Pages antes de integrarlo en documentos finales.
            </p>
            <p class="small"><strong>URL:</strong> {site.cvUrl}</p>
          </div>

          <img
            src={qrImage}
            alt="Código QR hacia la página de CV del portafolio profesional"
            class="qr-image"
            width="220"
            height="220"
          />
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
