---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/url';
---

<BaseLayout title="Dossier profesional | Henry Bory Prevez">
  <section class="section">
    <div class="container readable">
      <p class="eyebrow">Dossier</p>
      <h1>Dossier profesional de investigación</h1>
      <p class="lead">
        El dossier profesional presentará una síntesis institucional de trayectoria académica,
        líneas de investigación, publicaciones, software, proyectos y oportunidades de cooperación.
      </p>

      <div class="card">
        <h2>Contenido previsto</h2>
        <ul>
          <li>Resumen ejecutivo.</li>
          <li>Líneas de investigación.</li>
          <li>Publicaciones seleccionadas.</li>
          <li>Software y registros.</li>
          <li>Proyectos y aplicaciones.</li>
          <li>Propuesta de colaboración.</li>
        </ul>
      </div>

      <div class="button-row">
        <a class="button" href={withBase('cv/')}>Consultar CVs disponibles</a>
      </div>
    </div>
  </section>
</BaseLayout>
