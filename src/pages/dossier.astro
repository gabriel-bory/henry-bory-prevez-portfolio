---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/ui/PageIntro.astro';
import { sectionSummaries } from '../data/section-summaries';
---

<BaseLayout title="Dossier profesional | Henry Bory Prevez">
  <PageIntro {...sectionSummaries.dossier} actions={[{ label: 'Consultar CVs', href: 'cv/' }, { label: 'Ver publicaciones', href: 'publicaciones/', variant: 'secondary' }]} />
  <section class="section section-tight">
    <div class="container">
      <div class="card-grid">
        <article class="card"><h2>Trayectoria</h2><p>Síntesis académica, formación, docencia y experiencia científica.</p></article>
        <article class="card"><h2>Investigación</h2><p>Líneas principales y relación con publicaciones, software y proyectos.</p></article>
        <article class="card"><h2>Colaboración</h2><p>Propuesta institucional para cooperación académica, científica y tecnológica.</p></article>
      </div>
    </div>
  </section>
</BaseLayout>
