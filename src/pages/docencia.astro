---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/ui/PageIntro.astro';
import { sectionSummaries } from '../data/section-summaries';
---

<BaseLayout title="Docencia | Henry Bory Prevez">
  <PageIntro {...sectionSummaries.teaching} actions={[{ label: 'Ver perfil académico', href: 'sobre-mi/' }, { label: 'Ver publicaciones', href: 'publicaciones/', variant: 'secondary' }]} />
  <section class="section section-tight">
    <div class="container readable">
      <div class="card">
        <h2>Información por completar</h2>
        <ul>
          <li>Asignaturas impartidas.</li>
          <li>Tutorías de pregrado, maestría y doctorado.</li>
          <li>Tribunales académicos.</li>
          <li>Cursos de posgrado, conferencias y talleres.</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
