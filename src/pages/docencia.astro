---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Docencia | Henry Bory Prevez">
  <section class="section">
    <div class="container readable">
      <p class="eyebrow">Docencia</p>
      <h1>Docencia y formación académica</h1>
      <p class="lead">
        Como Profesor Titular de la Universidad de Oriente, la trayectoria del Dr. Henry Bory Prevez
        se vincula a la formación universitaria y a la investigación en ingeniería, automática,
        control, electrónica de potencia y modelado.
      </p>

      <div class="card">
        <h2>Información pendiente de completar</h2>
        <ul>
          <li>Asignaturas impartidas.</li>
          <li>Tutorías de pregrado, maestría y doctorado.</li>
          <li>Tribunales académicos.</li>
          <li>Cursos de posgrado, conferencias y talleres.</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
