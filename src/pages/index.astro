---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base}${path.replace(/^\//, '')}`;
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p><strong>Dr. en Ciencias · Profesor Titular · Universidad de Oriente</strong></p>
        <h1>Automática, energías renovables y modelado matemático aplicado.</h1>
        <p class="lead">
          Portafolio profesional de Henry Bory Prevez, especializado en control avanzado, electrónica de potencia,
          micro-hidroeléctricas, sistemas OTEC, energía undimotriz y biofísica computacional.
        </p>
        <div class="button-row">
          <a class="button" href={url('/cv')}>Descargar CV</a>
          <a class="button secondary" href={url('/publicaciones')}>Ver publicaciones</a>
        </div>
      </div>

      <div class="card">
        <h2>Áreas clave</h2>
        <ul>
          <li>Automática y control avanzado.</li>
          <li>Micro-hidroeléctricas y turbina Pelton.</li>
          <li>OTEC y energía oceánica.</li>
          <li>Biofísica computacional.</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
