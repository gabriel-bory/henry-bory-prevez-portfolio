---
import BaseLayout from '../layouts/BaseLayout.astro';
import { researchAreas } from '../data/research-areas';
import { sectionSummaries } from '../data/section-summaries';
import { withBase } from '../utils/url';

const profileImage = withBase('images/profile/henry-bory-prevez-profile.png');
const home = sectionSummaries.home;
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{home.eyebrow}</p>
        <h1>{home.title}</h1>
        <p class="lead">{home.lead}</p>
        <div class="button-row">
          <a class="button" href={withBase('cv/')}>Descargar CV</a>
          <a class="button secondary" href={withBase('publicaciones/')}>Ver publicaciones</a>
        </div>
      </div>

      <aside class="profile-panel" aria-label="Perfil profesional">
        <img src={profileImage} alt="Foto profesional del Dr. Henry Bory Prevez" class="profile-photo" loading="eager" width="420" height="520" />
        <div class="card">
          <h2>Qué encontrará en este sitio</h2>
          <p>{home.summary}</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Áreas de trabajo</p>
        <h2>Líneas de investigación y aplicación</h2>
      </div>

      <div class="card-grid">
        {researchAreas.map((area) => (
          <article class="card">
            <h3>{area.title}</h3>
            <p>{area.summary}</p>
            <a class="text-link" href={withBase(area.href)}>Explorar línea</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container split">
      <div>
        <p class="eyebrow">Trazabilidad y criterio editorial</p>
        <h2>Comunicación profesional basada en evidencia</h2>
        <p>
          El sitio separa publicaciones verificadas, líneas actuales en validación,
          software o registros documentados y contenidos pendientes de respaldo,
          de manera que la información se mantenga útil, profesional y responsable.
        </p>
      </div>

      <div class="card">
        <h3>Uso del portafolio</h3>
        <p>
          Este portafolio está diseñado para apoyar cooperación académica, presentación
          institucional, consulta de publicaciones, acceso a currículos descargables y
          futura expansión multilingüe.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
