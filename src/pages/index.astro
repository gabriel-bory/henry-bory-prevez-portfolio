---
import BaseLayout from '../layouts/BaseLayout.astro';
import { researchAreas } from '../data/research-areas';
import { withBase } from '../utils/url';

const profileImage = withBase('images/profile/henry-bory-prevez-profile.png');
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Dr. en Ciencias · Profesor Titular · Universidad de Oriente</p>

        <h1>Henry Bory Prevez</h1>

        <p class="lead">
          Portafolio profesional en Automática, control avanzado, electrónica de potencia,
          energías renovables, micro-hidroeléctricas, sistemas OTEC, energía undimotriz
          y modelado matemático aplicado.
        </p>

        <div class="button-row">
          <a class="button" href={withBase('cv/')}>Descargar CV</a>
          <a class="button secondary" href={withBase('publicaciones/')}>Ver publicaciones</a>
        </div>
      </div>

      <aside class="profile-panel" aria-label="Perfil profesional">
        <img
          src={profileImage}
          alt="Foto profesional del Dr. Henry Bory Prevez"
          class="profile-photo"
          loading="eager"
          width="420"
          height="520"
        />

        <div class="card">
          <h2>Perfil académico</h2>
          <p>
            Investigación, docencia universitaria y desarrollo científico aplicado a energía,
            control, simulación y sistemas complejos.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Áreas de trabajo</p>
        <h2>Líneas de investigación y aplicación</h2>
      </div>

      <div class="card-grid">
        {researchAreas.map((area) => (
          <article class="card">
            <h3>{area.title}</h3>
            <p>{area.summary}</p>
            <a class="text-link" href={withBase(area.href)}>Explorar línea</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container split">
      <div>
        <p class="eyebrow">Trazabilidad</p>
        <h2>Comunicación profesional basada en evidencia</h2>
        <p>
          El sitio separa publicaciones verificadas, líneas actuales en validación,
          software/registro y contenidos pendientes de respaldo documental.
        </p>
      </div>

      <div class="card">
        <h3>Próximo hito</h3>
        <p>
          Consolidar la página de CV descargables, validar la URL pública y usarla como destino
          del QR profesional en CV, dossier y presentación.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
