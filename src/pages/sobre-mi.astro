---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/ui/PageIntro.astro';
import { education, skills, internationalProjects, softwareRegisters } from '../data/profile-details';
import { sectionSummaries } from '../data/section-summaries';
import { withBase } from '../utils/url';
---

<BaseLayout title="Sobre mí | Henry Bory Prevez">
  <PageIntro {...sectionSummaries.about} actions={[{ label: 'Ver CV descargable', href: 'cv/' }, { label: 'Explorar investigación', href: 'investigacion/', variant: 'secondary' }]} />

  <section class="section section-tight">
    <div class="container readable">
      <h2>Formación académica</h2>
      <div class="timeline">
        {education.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p>{item.institution} · {item.location}</p>
            <p class="small">{item.year} · {item.evidenceStatus}</p>
          </article>
        ))}
      </div>

      <h2>Competencias técnicas</h2>
      <div class="tag-list">{skills.map((skill) => <span class="tag">{skill}</span>)}</div>

      <h2>Proyectos internacionales</h2>
      <div class="card-grid">
        {internationalProjects.map((project) => (
          <article class="card">
            <p class="eyebrow">{project.period}</p>
            <h3>{project.title}</h3>
            <p><strong>{project.fullName}</strong></p>
            <p>{project.summary}</p>
          </article>
        ))}
      </div>

      <h2>Software registrado</h2>
      <div class="tag-list">{softwareRegisters.map((item) => <span class="tag">{item}</span>)}</div>

      <div class="button-row">
        <a class="button" href={withBase('software/')}>Ver software</a>
        <a class="button secondary" href={withBase('publicaciones/')}>Ver publicaciones</a>
      </div>
    </div>
  </section>
</BaseLayout>
