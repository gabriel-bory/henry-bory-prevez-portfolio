---
import BaseLayout from '../layouts/BaseLayout.astro';
import { education, skills, internationalProjects, softwareRegisters } from '../data/profile-details';
import { withBase } from '../utils/url';
---

<BaseLayout title="Sobre mí | Henry Bory Prevez">
  <section class="section">
    <div class="container readable">
      <p class="eyebrow">Perfil académico</p>
      <h1>Sobre el Dr. Henry Bory Prevez</h1>

      <p class="lead">Doctor en Ciencias en Automática y Profesor Titular de la Universidad de Oriente, con trayectoria universitaria desde 2002 y trabajo científico en automática, electrónica de potencia, energías renovables, modelado y simulación.</p>

      <p>Su perfil integra docencia, investigación y desarrollo de software académico. El CV 2025 documenta formación en Automática, participación en proyectos internacionales como CRECE e IRIS, registros de software y publicaciones recientes en energía, laboratorios virtuales, OTEC, micro-hidroeléctricas y biofísica computacional.</p>

      <h2>Formación académica</h2>
      <div class="timeline">
        {education.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p>{item.institution} · {item.location}</p>
            <p class="small">{item.year} · {item.evidenceStatus}</p>
          </article>
        ))}
      </div>

      <h2>Competencias técnicas</h2>
      <div class="tag-list">{skills.map((skill) => <span class="tag">{skill}</span>)}</div>

      <h2>Proyectos internacionales</h2>
      <div class="card-grid">
        {internationalProjects.map((project) => (
          <article class="card">
            <p class="eyebrow">{project.period}</p>
            <h3>{project.title}</h3>
            <p><strong>{project.fullName}</strong></p>
            <p>{project.summary}</p>
          </article>
        ))}
      </div>

      <h2>Software registrado</h2>
      <div class="tag-list">{softwareRegisters.map((item) => <span class="tag">{item}</span>)}</div>

      <div class="button-row">
        <a class="button" href={withBase('cv/')}>Ver CV descargable</a>
        <a class="button secondary" href={withBase('investigacion/')}>Explorar investigación</a>
      </div>
    </div>
  </section>
</BaseLayout>
