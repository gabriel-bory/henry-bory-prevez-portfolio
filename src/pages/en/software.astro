<BaseLayout title="Software | Henry Bory Prevez">
  <PageIntro
    eyebrow="Software · records · academic tools"
    title="Software and technological solutions"
    lead="Registered or documented software, MATLAB tools, virtual laboratories and computational resources related to automatic control, power electronics, ocean energy, COVID-19, teaching, simulation and system analysis."
