<BaseLayout title="Research | Henry Bory Prevez">
  <PageIntro
    eyebrow="Research"
    title="Research lines"
    lead="Research work in automatic control, power electronics, renewable energy systems, micro-hydropower, OTEC, ocean energy, educational software and computational biophysics."
    summaryTitle="Scientific map"
    summary="The common axis is modelling, control and simulation of complex systems: from frequency regulation in isolated micro-hydropower and power converters to tumour-growth modelling, virtual laboratories and educational tools."
