---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { researchAreas } from '../../data/research-areas';
import { withBase } from '../../utils/url';
---

<BaseLayout title="Investigación | Henry Bory Prevez">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Investigación</p>
      <h1>Líneas de investigación</h1>
      <p class="lead">
        La actividad investigativa se organiza alrededor de la Automática, el control avanzado,
        la electrónica de potencia, el modelado matemático y sus aplicaciones en energía,
        simulación y sistemas complejos.
      </p>

      <div class="card-grid">
        {researchAreas.map((area) => (
          <article class="card">
            <h2>{area.title}</h2>
            <p>{area.summary}</p>
            <a class="text-link" href={withBase(area.href)}>Ver detalle</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
