---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/ui/PageIntro.astro';
import { researchAreas } from '../../data/research-areas';
import { sectionSummaries } from '../../data/section-summaries';
import { withBase } from '../../utils/url';
---

<BaseLayout title="Investigación | Henry Bory Prevez">
  <PageIntro {...sectionSummaries.research} actions={[{ label: 'Ver publicaciones', href: 'publicaciones/' }, { label: 'Ver proyectos', href: 'proyectos/', variant: 'secondary' }]} />

  <section class="section section-tight">
    <div class="container">
      <div class="card-grid">
        {researchAreas.map((area) => (
          <article class="card research-card">
            <h2>{area.title}</h2>
            <p>{area.summary}</p>
            <details>
              <summary>Resumen ampliado</summary>
              <p>{area.extendedSummary}</p>
              <ul>{area.keyPoints.map((point) => <li>{point}</li>)}</ul>
            </details>
            <a class="button secondary" href={withBase(area.href)}>Ver línea</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
