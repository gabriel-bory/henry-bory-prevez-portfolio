---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { researchAreas } from '../../data/research-areas';
import { withBase } from '../../utils/url';
---

<BaseLayout title="Investigación | Henry Bory Prevez">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Investigación</p>
      <h1>Líneas de investigación</h1>
      <p class="lead">Las líneas de investigación se organizan con resúmenes claros, botones de navegación y criterio de evidencia.</p>

      <div class="card-grid">
        {researchAreas.map((area) => (
          <article class="card research-card">
            <h2>{area.title}</h2>
            <p>{area.summary}</p>
            <details>
              <summary>Resumen ampliado</summary>
              <p>{area.extendedSummary}</p>
              <ul>{area.keyPoints.map((point) => <li>{point}</li>)}</ul>
            </details>
            <a class="button secondary" href={withBase(area.href)}>Ver línea</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
