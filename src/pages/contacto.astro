---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/ui/PageIntro.astro';
import { sectionSummaries } from '../data/section-summaries';
---

<BaseLayout title="Contacto | Henry Bory Prevez">
  <PageIntro {...sectionSummaries.contact} actions={[{ label: 'Ver CV', href: 'cv/' }, { label: 'Explorar investigación', href: 'investigacion/', variant: 'secondary' }]} />

  <section class="section section-tight">
    <div class="container readable">
      <div class="card">
        <h2>Áreas de colaboración</h2>
        <ul>
          <li>Automática y control avanzado.</li>
          <li>Electrónica de potencia.</li>
          <li>Micro-hidroeléctricas y microrredes aisladas.</li>
          <li>Sistemas OTEC y energía oceánica.</li>
          <li>Software científico y simulación.</li>
          <li>Biofísica computacional y modelado matemático.</li>
        </ul>
      </div>

      <div class="callout">Los datos de contacto públicos se incorporarán solo después de autorización explícita.</div>
    </div>
  </section>
</BaseLayout>
