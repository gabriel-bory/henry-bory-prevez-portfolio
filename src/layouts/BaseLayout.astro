---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.title,
  description = site.description,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base}${path.replace(/^\//, '')}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="container nav" aria-label="Navegación principal">
        <a href={url('/')} aria-label="Inicio"><strong>Henry Bory Prevez</strong></a>
        <div class="nav-links">
          <a href={url('/sobre-mi')}>Sobre mí</a>
          <a href={url('/investigacion')}>Investigación</a>
          <a href={url('/publicaciones')}>Publicaciones</a>
          <a href={url('/proyectos')}>Proyectos</a>
          <a href={url('/software')}>Software</a>
          <a href={url('/cv')}>CV</a>
          <a href={url('/contacto')}>Contacto</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p><strong>Dr. Henry Bory Prevez</strong> — Profesor Titular, Universidad de Oriente.</p>
        <p>Portafolio profesional en construcción. QR pendiente hasta publicar URL estable.</p>
      </div>
    </footer>
  </body>
</html>
