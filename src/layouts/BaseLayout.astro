---
import '../styles/global.css';
import { site } from '../data/site';
import { mainNavigation } from '../data/navigation';
import { withBase } from '../utils/url';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.title,
  description = site.description,
} = Astro.props;

const profileImage = withBase('images/profile/henry-bory-prevez-profile.png');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f3d5e" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
  </head>

  <body>
    <header class="site-header">
      <nav class="container nav" aria-label="Navegación principal">
        <a class="brand" href={withBase('')} aria-label="Inicio">
          <img
            src={profileImage}
            alt="Foto profesional del Dr. Henry Bory Prevez"
            class="brand-avatar"
            width="42"
            height="42"
          />
          <span>Henry Bory Prevez</span>
        </a>

        <div class="nav-actions">
          <button class="theme-toggle" type="button" aria-label="Cambiar modo claro u oscuro">
            <span aria-hidden="true">◐</span>
          </button>

          <button
            class="menu-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="main-menu"
          >
            Menú
          </button>
        </div>

        <div class="nav-links" id="main-menu">
          {mainNavigation.slice(1).map((item) => (
            <a href={withBase(item.href)}>{item.label}</a>
          ))}
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <p><strong>Dr. Henry Bory Prevez</strong></p>
          <p>Profesor Titular · Universidad de Oriente · Santiago de Cuba.</p>
        </div>

        <div>
          <p>
            Portafolio profesional en construcción. El QR apunta a la página de CV
            y debe validarse después del despliegue público.
          </p>
        </div>
      </div>
    </footer>

    <script>
      const root = document.documentElement;
      const savedTheme = localStorage.getItem('theme');

      if (savedTheme === 'light' || savedTheme === 'dark') {
        root.dataset.theme = savedTheme;
      }

      document.querySelector('.theme-toggle')?.addEventListener('click', () => {
        const current = root.dataset.theme;
        const next = current === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });

      const menuToggle = document.querySelector('.menu-toggle');
      const menu = document.querySelector('#main-menu');

      menuToggle?.addEventListener('click', () => {
        const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!expanded));
        menu?.classList.toggle('is-open');
      });

      menu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          menu.classList.remove('is-open');
          menuToggle?.setAttribute('aria-expanded', 'false');
        });
      });
    </script>
  </body>
</html>
