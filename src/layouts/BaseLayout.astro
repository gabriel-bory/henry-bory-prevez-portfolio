---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.title,
  description = site.description,
} = Astro.props;

const base = import.meta.env.BASE_URL;

const url = (path: string = '') => {
  const normalizedPath = path.replace(/^\/+/, '');
  return `${base}${normalizedPath}`;
};

const profileImage = `${base}images/profile/henry-bory-prevez-profile.png`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f3d5e" />
    <title>{title}</title>
  </head>

  <body>
    <header class="site-header">
      <nav class="container nav" aria-label="Navegación principal">
        <a class="brand" href={url()} aria-label="Inicio">
          <img
            src={profileImage}
            alt="Foto profesional del Dr. Henry Bory Prevez"
            class="brand-avatar"
            width="40"
            height="40"
          />
          <span>Henry Bory Prevez</span>
        </a>

        <div class="nav-actions">
          <button class="theme-toggle" type="button" aria-label="Cambiar modo claro u oscuro">
            <span aria-hidden="true">◐</span>
          </button>

          <button
            class="menu-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="main-menu"
          >
            Menú
          </button>
        </div>

        <div class="nav-links" id="main-menu">
          <a href={url('sobre-mi/')}>Sobre mí</a>
          <a href={url('investigacion/')}>Investigación</a>
          <a href={url('publicaciones/')}>Publicaciones</a>
          <a href={url('proyectos/')}>Proyectos</a>
          <a href={url('software/')}>Software</a>
          <a href={url('cv/')}>CV</a>
          <a href={url('contacto/')}>Contacto</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <p><strong>Dr. Henry Bory Prevez</strong></p>
          <p>Profesor Titular · Universidad de Oriente · Santiago de Cuba.</p>
        </div>

        <div>
          <p>
            Portafolio profesional en construcción. El QR definitivo se generará cuando la página
            de CV esté publicada y revisada.
          </p>
        </div>
      </div>
    </footer>

    <script>
      const root = document.documentElement;
      const savedTheme = localStorage.getItem('theme');

      if (savedTheme === 'light' || savedTheme === 'dark') {
        root.dataset.theme = savedTheme;
      }

      document.querySelector('.theme-toggle')?.addEventListener('click', () => {
        const current = root.dataset.theme;
        const next = current === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });

      const menuToggle = document.querySelector('.menu-toggle');
      const menu = document.querySelector('#main-menu');

      menuToggle?.addEventListener('click', () => {
        const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!expanded));
        menu?.classList.toggle('is-open');
      });
    </script>
  </body>
</html>
